# Root env reference for this single-artist EPK template.
#
# The server reads env from apps/server/.env during local development.
# Copy this file there when setting up a fresh template:
#
#   cp .env.example apps/server/.env
#
# Production must use a real database URL and a long random admin key.

DATABASE_URL=postgresql://postgres:password@localhost:5432/epk_db

# Internal single-record slug. Keep this as "site" unless you also update
# imports, uploads, and docs intentionally.
EPK_SLUG=site

# Required for dashboard saves and uploads. Do not deploy with this value.
ADMIN_API_KEY=change-me-to-a-long-random-secret
